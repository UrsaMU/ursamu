{
  "name": "@ursamu/cli",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./templates": "./src/create-templates.ts",
    "./ursamu": "./src/ursamu.ts",
    "./create": "./src/create.ts",
    "./plugin": "./src/plugin.ts",
    "./update": "./src/update.ts",
    "./scripts": "./src/scripts.ts",
    "./client": "./src/client.ts",
    "./start": "./src/start.ts"
  },
  "tasks": {
    "test":  "deno test tests/ --allow-all --unstable-kv --no-check",
    "lint":  "deno lint",
    "check": "deno check mod.ts --unstable-kv"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"]
  },
  "imports": {
    "@std/assert":  "jsr:@std/assert@^0.224.0",
    "@std/flags":   "jsr:@std/flags@^0.224.0",
    "@std/path":    "jsr:@std/path@^0.224.0",
    "@std/fs":      "jsr:@std/fs@^0.224.0",
    "@std/fmt":     "jsr:@std/fmt@^0.224.0",
    "@std/semver":  "jsr:@std/semver@^1.0.0",
    "@ursamu/mush": "../mush/mod.ts"
  },
  "publish": {
    "include": ["src", "mod.ts", "deno.json", "README.md"],
    "exclude": ["tests"]
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  }
}
