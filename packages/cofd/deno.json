{
  "name": "@ursamu/cofd-plugin",
  "version": "1.0.0",
  "description": "Chronicles of Darkness 2e plugin for UrsaMU — character sheets, guided chargen, and d10 dice with 10/9/8-again, rote, and Willpower spend.",
  "exports": "./index.ts",
  "tasks": {
    "test": "deno test -A --unstable-kv",
    "showcase": "deno run -A --unstable-kv --import-map=showcase.importmap.json tools/showcase.ts"
  },
  "exclude": [".claude/", "data/"],
  "publish": {
    "include": [
      "src",
      "help",
      "resources",
      "templates",
      "index.ts",
      "commands.ts",
      "cofd.ts",
      "cg.ts",
      "templates.ts",
      "routes.ts",
      "deno.json",
      "ursamu.plugin.json",
      "README.md"
    ],
    "exclude": ["tests", "tools", "showcases", "docs"]
  },
  "imports": {
    "ursamu": "../mush/mod.ts",
    "@ursamu/ursamu": "../mush/mod.ts",
    "@ursamu/mush": "../mush/mod.ts",
    "@ursamu/core": "../core/mod.ts",
    "@ursamu/cli": "../cli/mod.ts",
    "@ursamu/globals": "https://raw.githubusercontent.com/UrsaMU/ursamu-sgp-plugin/master/mod.ts",
    "@ursamu/help-plugin": "../help/mod.ts",
    "@ursamu/jobs-plugin": "../jobs/mod.ts",
    "@ursamu/mail-plugin": "https://raw.githubusercontent.com/UrsaMU/mail-plugin/v2.3.1/index.ts",
    "@ursamu/mushcode": "jsr:@ursamu/mushcode@^0.6.0",
    "@ursamu/mushcode/eval": "jsr:@ursamu/mushcode@^0.6.0/eval",
    "@ursamu/mushcode/parse": "jsr:@ursamu/mushcode@^0.6.0/parse",
    "@ursamu/parser": "npm:@ursamu/parser@1.2.4",
    "@digibear/tags": "npm:@digibear/tags@1.0.0",
    "bcrypt": "npm:bcryptjs@2.4.3",
    "djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "dotenv": "jsr:@std/dotenv@^0.224.0",
    "dotenv/": "jsr:@std/dotenv@^0.224.0/",
    "dotenv/load": "jsr:@std/dotenv@^0.224.0/load",
    "quickjs-emscripten": "npm:quickjs-emscripten@0.29.0",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "@std/testing/bdd": "jsr:@std/testing@^0.224.0/bdd",
    "@std/path": "jsr:@std/path@^0.224.0",
    "@std/fs": "jsr:@std/fs@^0.224.0",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/semver": "jsr:@std/semver@^1.0.0",
    "@std/fmt": "jsr:@std/fmt@^0.224.0",
    "@std/fmt/": "jsr:@std/fmt@^0.224.0/"
  }
}
