  "steps": [
    {
      "sub": "Arm Jax with a frag grenade"
    },
    {
      "cmd": "+gear/add grenade-frag-standard",
      "label": "buy a frag grenade"
    },
    {
      "expect": "grenade"
    },
    {
      "sub": "Open encounter and join"
    },
    {
      "cmd": "+combat/start",
      "as": "admin",
      "label": "open encounter"
    },
    {
      "expect": "encounter"
    },
    {
      "cmd": "+combat/join",
      "label": "Jax joins"
    },
    {
      "cmd": "+combat/join",
      "as": "Marcus",
      "label": "Marcus joins"
    },
    {
      "cmd": "+combat/join",
      "as": "Cass",
      "label": "Cass joins"
    },
    {
      "cmd": "+combat/begin",
      "as": "admin",
      "label": "roll initiative"
    },
    {
      "expect": "initiative"
    },
    {
      "sub": "Throw the grenade"
    },
    {
      "note": "Jax throws Dex 4 + Athletics 3 = 7 dice. No Defense applies (AoE). Marcus and Cass each contest with Stamina. Thrower is excluded from the blast by default."
    },
    {
      "cmd": "+throw grenade-frag-standard",
      "as": "Jax",
      "label": "Jax pulls the pin"
    },
    {
      "expect": "THROW"
    },
    {
      "sub": "Close the encounter"
    },
    {
      "cmd": "+combat/end",
      "as": "admin",
      "label": "end fight"
    },
    {
      "expect": "ended"
    },
    {
      "reset": true
    }
  ]
