{
  "key": "chargen-werewolf",
  "title": "+cg -- guided Werewolf: The Forsaken character generation",
  "description": "Full guided chargen walkthrough for a Werewolf: The Forsaken (WtF) template: Core Identity, Template, Template Specifics (auspice/tribe/blood/bone), Attributes (5/4/3), Skills (11/9/7), Merits (10 dots), and Renown (3 dots of Cunning/Glory/Honor/Purity/Wisdom) -- then submit for staff approval. Builds a Rahu of the Storm Lords.",
  "vars": { "player": "Stormcaller" },
  "steps": [
    { "sub": "Starting Werewolf: The Forsaken Character Generation" },
    { "note": "+cg with no prior state opens a fresh session and shows Stage 1." },
    { "cmd": "+cg",                                          "label": "start chargen" },
    { "expect": "Stage" },

    { "sub": "Stage 1 -- Core Identity" },
    { "note": "Set concept, virtue, vice. Template comes in Stage 2." },
    { "cmd": "+cg/set concept=First-changed soldier",        "label": "set concept" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set virtue=Loyal",                         "label": "set virtue" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set vice=Arrogant",                        "label": "set vice" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 2" },
    { "expect": "Stage" },

    { "sub": "Stage 2 -- Template" },
    { "cmd": "+cg/set template=werewolf",                    "label": "Werewolf: The Forsaken template" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 3" },
    { "expect": "Stage" },

    { "sub": "Stage 3 -- Template Specifics" },
    { "note": "Browse the canonical options before choosing. WtF adds auspices, tribes, Renown, Gifts, and Rites to +cg/list." },
    { "cmd": "+cg/list auspices",                            "label": "browse the five auspices" },
    { "expect": "Rahu" },
    { "cmd": "+cg/list tribes",                              "label": "browse the six tribes" },
    { "expect": "Storm Lords" },
    { "note": "WtF requires Auspice, Tribe, Blood, and Bone before advancing. Blood and Bone are free-form archetypes." },
    { "cmd": "+cg/set auspice=Rahu",                         "label": "Full Moon warrior" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set tribe=Storm Lords",                    "label": "set tribe" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set blood=Destroyer",                      "label": "set Blood archetype" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set bone=Soldier",                         "label": "set Bone archetype" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 4" },
    { "expect": "Stage" },

    { "sub": "Stage 4 -- Attributes (5/4/3 priority)" },
    { "note": "Extras above the free 1 in each must total 5/4/3 across the categories. A Rahu leans Physical." },
    { "cmd": "+cg/set strength=3",     "label": "Physical priority (+5)" },
    { "cmd": "+cg/set dexterity=3" },
    { "cmd": "+cg/set stamina=2" },
    { "cmd": "+cg/set presence=2",     "label": "Social secondary (+4)" },
    { "cmd": "+cg/set manipulation=2" },
    { "cmd": "+cg/set composure=3" },
    { "cmd": "+cg/set intelligence=2", "label": "Mental tertiary (+3)" },
    { "cmd": "+cg/set wits=2" },
    { "cmd": "+cg/set resolve=2" },
    { "cmd": "+cg/next",               "label": "advance to Stage 5" },
    { "expect": "Stage" },

    { "sub": "Stage 5 -- Skills (11/9/7 priority)" },
    { "note": "Per-category totals must hit 11/9/7 in some permutation. Brawl, Intimidation, and Survival are the Rahu's auspice skills." },
    { "cmd": "+cg/set brawl=3",          "label": "Physical group (11)" },
    { "cmd": "+cg/set athletics=3" },
    { "cmd": "+cg/set survival=2" },
    { "cmd": "+cg/set stealth=2" },
    { "cmd": "+cg/set weaponry=1" },
    { "cmd": "+cg/set occult=3",         "label": "Mental group (9)" },
    { "cmd": "+cg/set investigation=2" },
    { "cmd": "+cg/set academics=2" },
    { "cmd": "+cg/set medicine=2" },
    { "cmd": "+cg/set intimidation=3",   "label": "Social group (7)" },
    { "cmd": "+cg/set empathy=2" },
    { "cmd": "+cg/set persuasion=2" },
    { "cmd": "+cg/next",                 "label": "advance to Stage 6" },
    { "expect": "Stage" },

    { "sub": "Stage 6 -- Merits (10 dots)" },
    { "note": "Werewolves get 10 merit dots, three more than mortals or changelings. Allocate exactly 10." },
    { "cmd": "+cg/set contacts(pack)=2",      "label": "instanced merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set fast reflexes=3",       "label": "set fast reflexes merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set resources=3",           "label": "set resources merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set status(storm lords)=2", "label": "instanced tribal status" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                      "label": "advance to Stage 7" },
    { "expect": "Stage 7" },

    { "sub": "Stage 7 -- Renown (3 dots)" },
    { "note": "Werewolves get 3 Renown dots: one from auspice, one from tribe, one free. No single Renown may exceed 2 at creation. We put 2 in Purity so we can take a 2nd Moon facet later." },
    { "cmd": "+cg/set purity=2",              "label": "auspice Renown (Rahu), 2 dots" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set honor=1",               "label": "tribal Renown (Storm Lords)" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                      "label": "advance to Stage 8" },
    { "expect": "Stage" },

    { "sub": "Stage 8 -- Gifts & Rites" },
    { "note": "Full WtF package: 1 Moon facet (auspice), 2 Shadow facets from tribe Gifts, 1 flex (2nd Moon facet since Purity is 2), and 2 dots of Rites. Facets need a dot in their Renown." },
    { "note": "The Rahu's Moon Gift is the Full Moon's Gift; its facets are Purity. Storm Lord Shadow Gifts are Evasion, Dominance, Weather." },
    { "cmd": "+cg/gift Killer Instinct",      "label": "Moon facet 1 (Purity)" },
    { "expect": "Added Gift facet" },
    { "cmd": "+cg/gift Hit and Run",          "label": "Shadow facet -- Gift of Evasion (Purity)" },
    { "expect": "Added Gift facet" },
    { "cmd": "+cg/gift Snarl of the Predator","label": "Shadow facet -- Gift of Dominance (Purity)" },
    { "expect": "Added Gift facet" },
    { "cmd": "+cg/gift Warrior's Hide",       "label": "flex: 2nd Moon facet (Purity 2)" },
    { "expect": "Added Gift facet" },
    { "note": "Now 2 dots of Rites. Sacred Hunt is rank 2 -- exactly the starting allowance." },
    { "cmd": "+cg/rite Sacred Hunt",          "label": "rank-2 rite = 2 dots" },
    { "expect": "Added Rite" },

    { "sub": "Submit for Staff Approval" },
    { "note": "/submit at the final stage files a CGEN job. See approval-flow for what happens next." },
    { "cmd": "+cg/submit",  "label": "submit for review" },
    { "expect": "Submitted" }
  ]
}
