{
  "key": "chargen-changeling",
  "title": "+cg -- guided Changeling: The Lost character generation",
  "description": "Full guided chargen walkthrough for a Changeling: The Lost (CtL) template: Core Identity, Template, Template Specifics, Attributes (5/4/3), Skills (11/9/7), Merits (7 dots), and Powers (3 dots of Spring/Summer/Autumn/Winter/Royal/Eternal) -- then submit for staff approval.",
  "vars": { "player": "Novice" },
  "steps": [
    { "sub": "Starting Changeling: The Lost Character Generation" },
    { "note": "+cg with no prior state opens a fresh session and shows Stage 1." },
    { "cmd": "+cg",                                          "label": "start chargen" },
    { "expect": "Stage" },

    { "sub": "Stage 1 -- Core Identity" },
    { "note": "Set concept, virtue, vice. Template comes in Stage 2." },
    { "cmd": "+cg/set concept=Dream weaver escapee",         "label": "set concept" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set virtue=Just",                          "label": "set virtue" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set vice=Greedy",                          "label": "set vice" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 2" },
    { "expect": "Stage" },

    { "sub": "Stage 2 -- Template" },
    { "cmd": "+cg/set template=changeling",                  "label": "Changeling: The Lost template" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 3" },
    { "expect": "Stage" },

    { "sub": "Stage 3 -- Template Specifics" },
    { "note": "CtL requires Seeming, Kith, Court, a second favored Regalia, Needle, and Thread. Each seeming has its own favored Regalia (Fairest = Crown); the second must differ." },
    { "cmd": "+cg/set seeming=Fairest",                      "label": "set seeming (favors Crown)" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set kith=Dancer",                          "label": "set kith" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set court=Spring",                         "label": "set court" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set favored=Mirror",                       "label": "second favored Regalia" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set needle=Protector",                     "label": "set needle" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set thread=Believer",                      "label": "set thread" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                                     "label": "advance to Stage 4" },
    { "expect": "Stage" },

    { "sub": "Stage 4 -- Attributes (5/4/3 priority)" },
    { "note": "Extras above the free 1 in each must total 5/4/3 across the categories." },
    { "cmd": "+cg/set strength=2",     "label": "Physical priority (+5)" },
    { "cmd": "+cg/set dexterity=3" },
    { "cmd": "+cg/set stamina=3" },
    { "cmd": "+cg/set intelligence=2", "label": "Mental secondary (+3)" },
    { "cmd": "+cg/set wits=2" },
    { "cmd": "+cg/set resolve=2" },
    { "cmd": "+cg/set presence=2",     "label": "Social tertiary (+4)" },
    { "cmd": "+cg/set manipulation=3" },
    { "cmd": "+cg/set composure=2" },
    { "cmd": "+cg/next",               "label": "advance to Stage 5" },
    { "expect": "Stage" },

    { "sub": "Stage 5 -- Skills (11/9/7 priority)" },
    { "note": "Per-category totals must hit 11/9/7 in some permutation." },
    { "cmd": "+cg/set academics=3",      "label": "Mental group (11)" },
    { "cmd": "+cg/set investigation=3" },
    { "cmd": "+cg/set computer=2" },
    { "cmd": "+cg/set science=2" },
    { "cmd": "+cg/set medicine=1" },
    { "cmd": "+cg/set athletics=3",      "label": "Physical group (9)" },
    { "cmd": "+cg/set drive=2" },
    { "cmd": "+cg/set firearms=2" },
    { "cmd": "+cg/set weaponry=2" },
    { "cmd": "+cg/set empathy=3",        "label": "Social group (7)" },
    { "cmd": "+cg/set persuasion=2" },
    { "cmd": "+cg/set subterfuge=2" },
    { "cmd": "+cg/next",                 "label": "advance to Stage 6" },
    { "expect": "Stage" },

    { "sub": "Stage 6 -- Merits (7 dots)" },
    { "note": "Stage 6 is dedicated exclusively to merits. Allocate exactly 7 dots of merits." },
    { "cmd": "+cg/set contacts(goblins)=2",   "label": "instanced merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set resources=3",           "label": "set resources merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/set striking looks=2",      "label": "set striking looks merit" },
    { "expect": "Successfully set" },
    { "cmd": "+cg/next",                      "label": "advance to Stage 7" },
    { "expect": "Stage 7" },

    { "sub": "Stage 7 -- Contracts" },
    { "note": "Discrete gated selection: 4 Common (>=2 from a favored Regalia, <=2 Goblin) + 2 Royal (Royal Arcadian from a favored Regalia, or your Court). Favored Regalia here are Crown (seeming) and Mirror (chosen)." },
    { "note": "Browse the catalog: +cg/list contracts, then by group, e.g. +cg/list contracts crown." },
    { "cmd": "+cg/list contracts crown",                     "label": "browse Crown Regalia" },
    { "expect": "Crown" },
    { "cmd": "+cg/contract Mask of Superiority",             "label": "Common, favored (Crown)" },
    { "expect": "Added Contract" },
    { "cmd": "+cg/contract Hostile Takeover",               "label": "Common, favored (Crown)" },
    { "expect": "Added Contract" },
    { "cmd": "+cg/contract Goblin's Luck",                   "label": "Common, Goblin" },
    { "expect": "Added Contract" },
    { "cmd": "+cg/contract Cupid's Arrow",                   "label": "Common, Spring Court" },
    { "expect": "Added Contract" },
    { "cmd": "+cg/contract The Royal Court",                 "label": "Royal, favored (Crown)" },
    { "expect": "Added Contract" },
    { "cmd": "+cg/contract Blessing of Spring",             "label": "Royal, Spring Court" },
    { "expect": "Added Contract" },

    { "sub": "Submit for Staff Approval" },
    { "note": "/submit at Stage 7 files a CGEN job. See approval-flow for what happens next." },
    { "cmd": "+cg/submit",  "label": "submit for review" },
    { "expect": "Submitted" }
  ]
}
