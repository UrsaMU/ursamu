{
  "key": "integrity-break",
  "title": "+integrity -- Breaking Points and the Integrity track",
  "description": "Demonstrates +integrity view, /break (self and ST-initiated), and /set. Conditions granted feed into the +condition catalog.",
  "vars": { "player": "Katya" },
