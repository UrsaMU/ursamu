  "steps": [
    { "sub": "Viewing Integrity" },
    { "note": "Starts at 7 dots for mortals (CoFD 2e default). Display is N/10 plus a dot bar." },
    { "cmd": "+integrity", "label": "view own Integrity" },
    { "expect": "Integrity: 7/10" },

    { "sub": "Self-triggered Breaking Point" },
    { "note": "+integrity/break <reason> rolls Resolve + Composure + Integrity-mod. Witnessing a murder is -3 per RAW p.74." },
    { "cmd": "+integrity/break Saw a man stabbed in an alley -3", "label": "breaking point with -3 situational mod" },
    { "expect": "Outcome" },

    { "sub": "Direct ST adjustment" },
    { "note": "+integrity/set <n> -- staff override. Self-edit allowed; cross-player requires canEdit (builder+)." },
    { "cmd": "+integrity/set 5", "label": "drop yourself to Integrity 5" },
    { "expect": "Integrity set to 5/10" },
    { "cmd": "+integrity", "label": "confirm" },
    { "expect": "Integrity: 5/10" },

    { "sub": "Invalid input" },
    { "cmd": "+integrity/set 12", "label": "out of range" },
    { "expect": "0 to 10" },

    { "sub": "Unknown switch" },
    { "cmd": "+integrity/xyzzy", "label": "unknown" },
    { "expect": "Unknown" }
  ]
}
