{
  "key": "npc-flow",
  "title": "+npc -- spawn, fight, and destroy NPC antagonists",
  "description": "Admin spawns a Thug NPC, joins it to a combat encounter, attacks it, then destroys the NPC at scene end.",
  "vars": { "player": "Jax" },
  "setup": {
    "targets": {
      "Jax": {
        "flags": ["player", "connected"],
        "state": {
          "cofd": {
            "template": "mortal",
            "attributes": {
              "intelligence": 2, "wits": 2, "resolve": 2,
              "strength": 3, "dexterity": 2, "stamina": 2,
              "presence": 2, "manipulation": 2, "composure": 2
            },
            "skills": { "brawl": 2, "athletics": 2 },
            "advantages": { "willpowerMax": 4, "willpowerCurrent": 4, "size": 5 },
            "health": { "bashing": 0, "lethal": 0, "aggravated": 0 },
            "equipment": { "equippedWeapon": null, "equippedArmor": null }
          }
        }
      }
    }
  },
  "steps": [
    { "sub": "Browse NPC List in an Empty Room" },
    { "note": "Anyone connected can /list; it shows available archetypes if the room has no NPCs." },
    { "cmd": "+npc", "label": "Jax checks the room" },
    { "expect": "Archetypes" },

    { "sub": "Staff Spawns a Thug" },
    { "note": "Only admin/builder can /create. The NPC becomes a real IDBObj flagged 'npc'." },
    { "cmd": "+npc/create Goon=thug", "as": "admin", "label": "ST drops in a thug" },
    { "expect": "Created" },

    { "sub": "List Shows the New NPC" },
    { "cmd": "+npc/list", "label": "Jax sees Goon in the room" },
    { "expect": "Goon" },

    { "sub": "Open Combat and Bring the NPC In" },
    { "cmd": "+combat/start", "as": "admin", "label": "ST opens the encounter" },
    { "expect": "encounter" },
    { "cmd": "+combat/join", "label": "Jax joins" },
    { "expect": "joined" },
    { "cmd": "+combat/join", "as": "Goon", "label": "Goon (NPC) joins the order" },
    { "expect": "joined" },
    { "cmd": "+combat/begin", "as": "admin", "label": "Roll initiative" },
    { "expect": "initiative" },

    { "sub": "Round 1 -- Combat Plays Out" },
    { "note": "Goon attacks Jax. Initiative was random; Goon may not have been first, so we advance to whichever turn order produced this." },
    { "cmd": "+attack Jax", "as": "Goon", "label": "Goon attacks (no-op if not their turn)" },
    { "expect": "attack" },
    { "cmd": "+combat/next", "as": "admin", "label": "ST advances the turn" },
    { "expect": "turn" },
    { "cmd": "+attack Goon", "label": "Jax retaliates (no-op if not their turn)" },
    { "expect": "attack" },

    { "sub": "Close the Scene and Clean Up" },
    { "cmd": "+combat/end", "as": "admin", "label": "ST ends the fight" },
    { "expect": "ended" },
    { "cmd": "+npc/destroy Goon", "as": "admin", "label": "ST removes the NPC" },
    { "expect": "Destroyed" },

    { "reset": true }
  ]
}
