{
  "name": "@ursamu/builder",
  "version": "1.3.0",
  "exports": "./mod.ts",
  "tasks": {
    "test":  "deno test tests/ --allow-all --unstable-kv --no-check",
    "lint":  "deno lint",
    "check": "deno check mod.ts --unstable-kv"
  },
  "compilerOptions": { "lib": ["deno.window", "deno.unstable"] },
  "imports": {
    "@std/assert":  "jsr:@std/assert@^0.224.0"
  },
  "publish": {
    "include": ["src", "mod.ts", "deno.json", "README.md"],
    "exclude": ["tests"]
  },
  "lint": { "rules": { "tags": ["recommended"] } }
}
