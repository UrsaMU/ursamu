{
  "key": "mekton-chargen",
  "label": "Mekton Zeta Character Generation",
  "plugin": "mekton-zeta",
  "steps": [
    { "sub": "Starting Chargen" },
    { "note": "View current chargen status checklist before draft creation." },
    { "cmd": "+chargen", "label": "Show checklist" },
    { "note": "Begin character generation and create a draft." },
    { "cmd": "+chargen/start", "label": "Start chargen draft" },
    { "note": "Use the guided instructions command to see the next step." },
    { "cmd": "+chargen/next", "label": "Guided next step (Method)" },
    { "cmd": "+chargen", "label": "Show checklist after starting" },

    { "sub": "Stat Allocation Methods" },
    { "note": "Set the stat generation method to random, cinematic, or concept." },
    { "cmd": "+chargen/method random", "label": "Set generation method to random" },
    { "cmd": "+chargen/method cinematic", "label": "Set generation method to cinematic" },
    { "cmd": "+chargen/method concept", "label": "Set generation method to concept" },
    { "note": "Allocate primary stats (minimum 2, maximum 10)." },
    { "cmd": "+chargen/stat att=6", "label": "Set ATT to 6" },
    { "cmd": "+chargen/stat bod=6", "label": "Set BOD to 6" },
    { "cmd": "+chargen/stat cl=6", "label": "Set CL to 6" },
    { "cmd": "+chargen/stat emp=6", "label": "Set EMP to 6" },
    { "cmd": "+chargen/stat int=6", "label": "Set INT to 6" },
    { "cmd": "+chargen/stat luck=6", "label": "Set LUCK to 6" },
    { "cmd": "+chargen/stat ma=6", "label": "Set MA to 6" },
    { "cmd": "+chargen/stat ref=8", "label": "Set REF to 8" },
    { "cmd": "+chargen/stat tech=6", "label": "Set TECH to 6" },
    { "cmd": "+chargen/stat edu=6", "label": "Set EDU to 6" },
    { "cmd": "+chargen", "label": "Check stats in checklist" },

    { "sub": "Lifepath Generation" },
    { "note": "Auto-roll basic lifepath charts including status, standing, siblings, and friends." },
    { "cmd": "+chargen/roll-lifepath", "label": "Roll all basic lifepath steps" },
    { "cmd": "+chargen/lifepath", "label": "View the generated lifepath details" },
    { "note": "Manually customize appearance fields on the lifepath." },
    { "cmd": "+chargen/lifepath/set hairColor=Neon Green", "label": "Customize hair color" },
    { "cmd": "+chargen/lifepath/set personalityTrait=Brooding, intense", "label": "Customize personality" },
    { "cmd": "+chargen/lifepath", "label": "View the modified lifepath details" },

    { "sub": "Rookie Template Selection" },
    { "note": "Set character type to rookie to explore rookie templates." },
    { "cmd": "+chargen/type rookie", "label": "Set character type to rookie" },
    { "note": "List available rookie templates." },
    { "cmd": "+chargen/list templates", "label": "List templates" },
    { "note": "Apply a rookie template." },
    { "cmd": "+chargen/template Anime Hero", "label": "Apply Anime Hero template" },

    { "sub": "Professional Career Path" },
    { "note": "Switch character type to professional to explore careers." },
    { "cmd": "+chargen/type professional", "label": "Set character type to professional" },
    { "note": "List available professions." },
    { "cmd": "+chargen/list careers", "label": "List professions" },
    { "note": "Add a career term." },
    { "cmd": "+chargen/career Mechajock/Combat", "label": "Add Mechajock term" },
    { "note": "Allocate career term skills." },
    { "cmd": "+chargen/career/skills 1=Mecha Piloting,Mecha Gunnery,Handgun,Awareness/Notice,Mecha Melee", "label": "Select term skills" },
    { "note": "List current skill choices." },
    { "cmd": "+chargen/skills", "label": "View current skill selections" },
    { "note": "Remove the last career term." },
    { "cmd": "+chargen/career/remove", "label": "Remove career term" },
    { "note": "Re-add career term and assign skills." },
    { "cmd": "+chargen/career Mechajock/Combat", "label": "Add Mechajock term again" },
    { "cmd": "+chargen/career/skills 1=Mecha Piloting,Mecha Gunnery,Handgun,Awareness/Notice,Mecha Melee", "label": "Assign term skills again" },
    
    { "sub": "Equipment Purchase" },
    { "note": "Browse the melee weapon category in the catalog." },
    { "cmd": "+gear/catalog melee", "label": "Browse melee weapons" },
    { "note": "Buy a Combat Knife for ¥50 using starting cash." },
    { "cmd": "+gear/buy Combat Knife", "label": "Buy Combat Knife" },
    { "note": "View current equipment inventory." },
    { "cmd": "+gear", "label": "List equipment" },

    { "sub": "Submission & Staff Review" },
    { "note": "Submit the completed character sheet for review." },
    { "cmd": "+chargen/submit", "label": "Submit draft character" },
    { "note": "Staff lists pending characters." },
    { "cmd": "+chargen/pending", "as": "admin", "label": "List pending characters (Admin)" },
    { "note": "Staff views the submitted character sheet." },
    { "cmd": "+chargen/view Showcase Player", "as": "admin", "label": "View Alice's sheet (Admin)" },
    { "note": "Staff returns the character for revision." },
    { "cmd": "+chargen/reject Showcase Player=Please lower REF to 7", "as": "admin", "label": "Reject character (Admin)" },
    { "note": "Player adjusts REF to 7." },
    { "cmd": "+chargen/stat ref=7", "label": "Adjust Reflexes to 7" },
    { "note": "Player re-submits the character sheet." },
    { "cmd": "+chargen/submit", "label": "Re-submit character" },
    { "note": "Staff approves the character." },
    { "cmd": "+chargen/approve Showcase Player", "as": "admin", "label": "Approve character (Admin)" },

    { "sub": "Character Sheet" },
    { "note": "View the fully approved and locked character sheet." },
    { "cmd": "+sheet", "label": "Show character sheet" }
  ]
}
