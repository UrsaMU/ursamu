# ─── AI-GM Environment Variables ────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Required: Google Gemini API key
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Stripe payment integration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Discord webhook for mirroring GM output to a channel
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: Bearer token for the REST API (/api/gm/*)
# Leave unset to run the API open in development.
GM_API_SECRET=

# Optional: Base URL for Stripe payment redirect links
GAME_URL=https://yourgame.example.com

# Optional: Base URL for wiki lore tools
WIKI_BASE_URL=http://localhost:4201
