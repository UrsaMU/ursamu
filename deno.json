{
  "workspace": ["packages/core", "packages/mush", "packages/channels", "packages/builder", "packages/cli", "packages/mail", "packages/events", "packages/discord", "packages/help", "packages/jobs", "packages/bbs", "packages/wiki", "packages/cofd", "packages/mekton", "packages/ai-gm", "packages/map", "games/roses"],
  "nodeModulesDir": "auto",

  "name": "@ursamu/ursamu",

  "version": "3.0.0",
  "description": "A modern, high-performance MUSH-like engine built with TypeScript and Deno.",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./packages/cli/src/ursamu.ts",
    "./start": "./packages/cli/src/start.ts",
    "./app": "./packages/mush/src/app.ts",
    "./channels": "./packages/channels/src/channel-events.ts"
  },
  "publish": {
    "include": [
      "src",
      "system",
      "scripts",
      "mod.ts",
      "deno.json",
      "deps.ts",
      "LICENSE",
      "README.md",
      "text",
      "help"
    ],
    "exclude": ["tests", "data"]
  },
  "tasks": {
    "start": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./packages/cli/src/start.ts",
    "dev": "bash ./scripts/run.sh",
    "daemon": "bash ./scripts/daemon.sh",
    "stop": "bash ./scripts/stop.sh",
    "restart": "bash ./scripts/restart.sh",
    "status": "bash ./scripts/status.sh",
    "logs": "tail -f logs/main.log logs/telnet.log",
    "server": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./packages/mush/src/main.ts",
    "telnet": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./packages/mush/src/telnet.ts",
    "config": "deno run -A ./packages/cli/src/config.ts",
    "setup-config": "bash ./scripts/setup-config.sh",
    "create-plugin": "bash ./scripts/create-plugin.sh",
    "create": "deno run -A ./packages/cli/src/create.ts",
    "create:local": "deno run -A ./packages/cli/src/create.ts --local",
    "cli": "deno run -A ./packages/cli/src/ursamu.ts",
    "install-cli": "deno install --allow-all --name ursamu --global --force ./packages/cli/src/ursamu.ts",
    "client": "deno run -A ./packages/cli/src/client.ts",
    "test": "deno test --allow-all --unstable-kv --unstable-detect-cjs --no-check",
    "showcase": "deno run -A ./packages/cli/src/showcase.ts",
    "upgrade": "deno run -A ./packages/cli/src/ursamu.ts update",
    "upgrade:reload": "deno run -A ./packages/cli/src/ursamu.ts update && deno run --reload -A --unstable-detect-cjs --unstable-kv ./packages/mush/src/main.ts",
    "test:coverage": "deno test --allow-all --unstable-kv --unstable-detect-cjs --no-check --coverage=coverage && deno coverage coverage --lcov > coverage/lcov.info && deno coverage coverage",
    "docker:build": "docker build -t ursamu .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "boundaries": "deno run -A tools/check-boundaries.ts",
    "packages:test": "deno test packages/*/tests/ --allow-all --unstable-kv --no-check",
    "packages:check": "deno check packages/core/mod.ts packages/mush/mod.ts --unstable-kv",
    "packages:lint": "deno lint packages/"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"]
  },
  "imports": {
    "@ursamu/bbs":            "./packages/bbs/mod.ts",
    "@ursamu/wiki":           "./packages/wiki/mod.ts",
    "@ursamu/core":           "./packages/core/mod.ts",
    "@ursamu/mush":           "./packages/mush/mod.ts",
    "@ursamu/cli":            "./packages/cli/mod.ts",
    "@ursamu/cli/templates":  "./packages/cli/src/create-templates.ts",
    "@ursamu/help":           "./packages/help/mod.ts",
    "@ursamu/jobs":           "./packages/jobs/mod.ts",
    "@ursamu/mail":           "./packages/mail/mod.ts",
    "@ursamu/events":         "./packages/events/mod.ts",
    "@ursamu/discord":        "./packages/discord/mod.ts",
    "@ursamu/ai-gm":          "./packages/ai-gm/mod.ts",
    "@ursamu/map-plugin":     "./packages/map/index.ts",
    "@ursamu/ursamu":         "./mod.ts",
    "@ursamu/globals":        "https://raw.githubusercontent.com/UrsaMU/ursamu-sgp-plugin/master/mod.ts",
    "@nicia-ai/typegraph":    "npm:@nicia-ai/typegraph@^0.31.0",
    "@nicia-ai/typegraph/postgres/pglite": "npm:@nicia-ai/typegraph@^0.31.0/postgres/pglite",
    "@ursamu/help-plugin":    "./packages/help/mod.ts",
    "@ursamu/jobs-plugin":    "./packages/jobs/mod.ts",
    "@ursamu/mail-plugin":    "https://raw.githubusercontent.com/UrsaMU/mail-plugin/v2.3.1/index.ts",
    "@ursamu/ursamu/app": "./packages/mush/src/app.ts",
    "@ursamu/ursamu/channels": "./packages/channels/src/channel-events.ts",
    "@ursamu/ursamu/jobs": "./packages/jobs/mod.ts",
    "ursamu": "./mod.ts",
    "ursamu/": "./",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/path": "jsr:@std/path@^0.224.0",
    "@std/fs": "jsr:@std/fs@^0.224.0",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "$std/": "jsr:@std/std@^0.224.0/",
    "bcrypt": "npm:bcryptjs@2.4.3",
    "lodash": "npm:lodash@4.17.21",
    "djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "quickjs-emscripten": "npm:quickjs-emscripten@0.29.0",
    "@ursamu/mushcode": "jsr:@ursamu/mushcode@^0.6.0",
    "@ursamu/mushcode/eval": "jsr:@ursamu/mushcode@^0.6.0/eval",
    "@ursamu/mushcode/parse": "jsr:@ursamu/mushcode@^0.6.0/parse",
    "dotenv": "jsr:@std/dotenv@^0.224.0",
    "dotenv/": "jsr:@std/dotenv@^0.224.0/",
    "dotenv/load": "jsr:@std/dotenv@^0.224.0/load",
    "@ursamu/parser": "npm:@ursamu/parser@1.2.4",
    "@digibear/tags": "npm:@digibear/tags@1.0.0",
    "@std/fmt": "jsr:@std/fmt@^0.224.0",
    "@std/fmt/": "jsr:@std/fmt@^0.224.0/",
    "@std/semver": "jsr:@std/semver@^1.0.0",
        "@std/testing": "jsr:@std/testing@^1.0.17",
        "@std/testing/bdd": "jsr:@std/testing@^1.0.17/bdd",
        "@std/testing/mock": "jsr:@std/testing@^1.0.17/mock",
    "@langchain/google-genai": "npm:@langchain/google-genai@^0.2.0",
    "@langchain/langgraph": "npm:@langchain/langgraph@^0.2.0",
    "@langchain/langgraph/prebuilt": "npm:@langchain/langgraph@^0.2.0/prebuilt",
    "@langchain/core": "npm:@langchain/core@^0.3.0",
    "zod": "npm:zod@4.4.3",
    "stripe": "npm:stripe@^17.0.0",
    "unpdf": "npm:unpdf@^0.11.0"
  },
  "exclude": ["docs/_site", "config", ".claude"],
  "lint": {
    "rules": { "tags": ["recommended"] },
    "exclude": ["src/services/Softcode/parser.cjs", "legends"]
  }
}
