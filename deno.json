{
  "name": "@ursamu/ursamu",

  "version": "1.9.31",
  "description": "A modern, high-performance MUSH-like engine built with TypeScript and Deno.",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./src/cli/ursamu.ts",
    "./start": "./src/cli/start.ts",
    "./app": "./src/app.ts",
    "./channels": "./src/services/channel-events.ts"
  },
  "publish": {
    "include": [
      "src",
      "system",
      "scripts",
      "mod.ts",
      "deno.json",
      "deps.ts",
      "LICENSE",
      "README.md",
      "text",
      "help"
    ],
    "exclude": ["tests", "data"]
  },
  "tasks": {
    "start": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./src/cli/start.ts",
    "dev": "bash ./scripts/run.sh",
    "daemon": "bash ./scripts/daemon.sh",
    "stop": "bash ./scripts/stop.sh",
    "restart": "bash ./scripts/restart.sh",
    "status": "bash ./scripts/status.sh",
    "logs": "tail -f logs/main.log logs/telnet.log",
    "server": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./src/main.ts",
    "telnet": "deno run -A --unstable-detect-cjs --unstable-kv --unstable-net ./src/telnet.ts",
    "config": "deno run -A ./src/cli/config.ts",
    "setup-config": "bash ./scripts/setup-config.sh",
    "create-plugin": "bash ./scripts/create-plugin.sh",
    "create": "deno run -A ./src/cli/create.ts",
    "cli": "deno run -A ./src/cli/ursamu.ts",
    "install-cli": "deno install --allow-all --name ursamu --global --force ./src/cli/ursamu.ts",
    "test": "deno test --allow-all --unstable-kv --no-check",
    "upgrade": "deno run -A ./src/cli/ursamu.ts update",
    "upgrade:reload": "deno run -A ./src/cli/ursamu.ts update && deno run --reload -A --unstable-detect-cjs --unstable-kv ./src/main.ts",
    "test:coverage": "deno test --allow-all --unstable-kv --no-check --coverage=coverage && deno coverage coverage --lcov > coverage/lcov.info && deno coverage coverage",
    "docker:build": "docker build -t ursamu .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.unstable"]
  },
  "imports": {
    "@ursamu/ursamu": "jsr:@ursamu/ursamu@^1.9.5",
    "ursamu": "./mod.ts",
    "ursamu/": "./",
    "@std/flags": "jsr:@std/flags@^0.224.0",
    "@std/path": "jsr:@std/path@^0.224.0",
    "@std/fs": "jsr:@std/fs@^0.224.0",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "$std/": "jsr:@std/std@^0.224.0/",
    "bcrypt": "npm:bcryptjs@2.4.3",
    "lodash": "npm:lodash@^4.17.23",
    "djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "quickjs-emscripten": "npm:quickjs-emscripten@0.29.0",
    "@ursamu/parser": "npm:@ursamu/parser@1.2.4",
    "dotenv": "jsr:@std/dotenv@^0.224.0",
    "dotenv/": "jsr:@std/dotenv@^0.224.0/",
    "dotenv/load": "jsr:@std/dotenv@^0.224.0/load",
    "@digibear/tags": "npm:@digibear/tags@1.0.0",
    "@std/fmt": "jsr:@std/fmt@^0.224.0",
    "@std/fmt/": "jsr:@std/fmt@^0.224.0/",
    "@std/semver": "jsr:@std/semver@^1.0.0",
        "@std/testing": "jsr:@std/testing@^1.0.17",
        "@std/testing/bdd": "jsr:@std/testing@^1.0.17/bdd",
        "@std/testing/mock": "jsr:@std/testing@^1.0.17/mock"
  },
  "exclude": ["docs/_site", "config", ".claude"],
  "lint": { "rules": { "tags": ["recommended"] } }
}
